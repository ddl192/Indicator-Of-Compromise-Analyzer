{
  "api_key": "YOUR_VIRUSTOTAL_API_KEY_HERE",
  "rate_limit_delay": 1,
  "enable_vt_checks": true,
  "check_file_hashes": true,
  "check_ip_addresses": true,
  "check_domains": true,
  "check_urls": true,
